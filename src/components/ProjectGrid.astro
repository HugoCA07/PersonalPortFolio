---
const projects = [
	{
		title: "TERRAFORGE",
		description: "A 2D sandbox game engine with procedural generation. Built from scratch in C++ and SFML, featuring a custom physics system, tileset rendering, and an ECS-based architecture.",
		link: "https://github.com/HugoCA07/TerraForge",
		icon: "engine",
		image: "/terraforge.jpg"
	},
	{
		title: "Building...",
		description: "Currently developing a new full-stack application. Focusing on robust architecture, performance, and modern design principles. Stay tuned.",
		link: "#",
		icon: "build",
		image: "https://images.unsplash.com/photo-1555066931-4365d14bab8c?q=80&w=2560&auto=format&fit=crop"
	},
	{
		title: "Work In Progress",
		description: "Another exciting project is currently under construction. Experimenting with new technologies to deliver a premium user experience.",
		link: "#",
		icon: "wip",
		image: "https://images.unsplash.com/photo-1517694712202-14dd9538aa97?q=80&w=2560&auto=format&fit=crop"
	}
];
---

<section id="projects" class="py-32 max-w-[100rem] mx-auto relative z-10">
	<div class="mb-24 px-4 lg:px-12 flex flex-col md:flex-row md:items-end justify-between gap-8">
		<div>
			<h2 class="text-xs font-bold tracking-[0.2em] text-[var(--accent-red)] mb-4 uppercase">Featured Work</h2>
			<h3 class="text-5xl lg:text-7xl font-bold text-white tracking-tighter uppercase font-clash">Selected Projects</h3>
		</div>
		<p class="text-slate-400 font-light max-w-md text-lg">
			A curated selection of my most technically challenging and visually impactful builds.
		</p>
	</div>
	
	<div class="flex flex-col border-t struct-border-t">
		{projects.map((project, index) => (
			<a href={project.link} target="_blank" rel="noopener noreferrer" class="group relative block w-full border-b struct-border-b py-12 md:py-20 hover:bg-white/[0.02] active:bg-white/[0.05] transition-colors duration-500 reveal-on-scroll opacity-0 translate-y-12">
				
				<div class="flex flex-col md:flex-row md:items-center justify-between gap-8 relative z-10 px-4 lg:px-12">
					<div class="flex items-start gap-4 md:gap-12">
						<span class="text-[var(--accent-red)] font-mono text-sm tracking-widest mt-2 block md:w-12">0{index + 1} //</span>
						<h4 class="text-4xl md:text-7xl lg:text-8xl font-black text-white md:text-slate-600 md:group-hover:text-white uppercase font-clash tracking-tighter transition-colors duration-500 relative z-20 mix-blend-difference">{project.title}</h4>
					</div>
					
					<div class="md:w-1/4 flex flex-col justify-end text-left md:text-right">
						<p class="text-slate-400 font-light text-sm md:text-base opacity-100 md:opacity-0 group-hover:opacity-100 transform md:translate-y-4 group-hover:translate-y-0 transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]">{project.description}</p>
					</div>
				</div>

				<!-- Project Image (Inline on mobile, Floating on Desktop) -->
				<div class="relative mt-8 mx-4 md:mx-0 md:mt-0 md:absolute md:top-1/2 md:right-[20%] md:-translate-y-1/2 w-[calc(100%-2rem)] md:w-[35vw] md:max-w-[500px] aspect-[16/10] z-0 opacity-100 md:opacity-0 md:group-hover:opacity-100 scale-100 md:scale-90 md:group-hover:scale-100 pointer-events-none transition-all duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] overflow-hidden shadow-[0_30px_60px_rgba(0,0,0,0.8)] struct-border">
					<img src={project.image} alt={project.title} class="w-full h-full object-cover grayscale-0 md:grayscale md:mix-blend-luminosity md:group-hover:grayscale-0 md:group-hover:mix-blend-normal transition-all duration-1000 scale-100 md:scale-110 md:group-hover:scale-100" />
					<div class="absolute inset-0 bg-[#111] mix-blend-multiply opacity-20 md:opacity-50"></div>
				</div>
				
			</a>
		))}
	</div>
</section>
