---
---
<div class="w-full h-full relative overflow-hidden" id="wind-tunnel-container">
	<canvas id="wind-tunnel" class="absolute inset-0 w-full h-full pointer-events-auto"></canvas>
</div>

<script>
	const canvas = document.getElementById('wind-tunnel') as HTMLCanvasElement;
	const container = document.getElementById('wind-tunnel-container');
	
	if (canvas && container) {
		const ctx = canvas.getContext('2d');
		let width: number, height: number;
		
		let particles: Particle[] = [];
		const particleCount = 180;
		
		let mouse = {
			x: -1000,
			y: -1000,
			radius: 120
		};
		
		function initSize() {
			width = container!.clientWidth;
			height = container!.clientHeight;
			canvas.width = width;
			canvas.height = height;
		}
		
		class Particle {
			x: number;
			y: number;
			baseY: number;
			length: number;
			speed: number;
			isCyan: boolean;
			
			constructor() {
				this.x = 0;
				this.y = 0;
				this.baseY = 0;
				this.length = 0;
				this.speed = 0;
				this.isCyan = false;
				this.reset();
				this.x = Math.random() * width; // Random start X for initial distribution
			}
			
			reset() {
				this.x = width + Math.random() * 200; // Start off-screen right
				this.baseY = Math.random() * height;
				this.y = this.baseY;
				this.length = Math.random() * 80 + 20; // Random length between 20 and 100
				this.speed = Math.random() * 4 + 2; // Random speed between 2 and 6
				this.isCyan = Math.random() < 0.1; // 10% chance to be cyan
			}
			
			update() {
				this.x -= this.speed;
				
				// Mouse interaction (Repel effect)
				let dy = mouse.y - this.y;
				let dx = mouse.x - this.x;
				let distance = Math.sqrt(dx * dx + dy * dy);
				
				if (distance < mouse.radius) {
					// Repel heavily on Y axis
					let forceDirectionY = dy / distance;
					let force = (mouse.radius - distance) / mouse.radius;
					this.y -= forceDirectionY * force * 10;
					
					// Slight acceleration when pushed
					this.x -= force * 2;
				} else {
					// Ease back to original horizontal track
					this.y += (this.baseY - this.y) * 0.05;
				}
				
				// Reset when particle goes out of bounds on the left
				if (this.x + this.length < 0) {
					this.reset();
				}
			}
			
			draw() {
				if (!ctx) return;
				ctx.beginPath();
				ctx.moveTo(this.x, this.y);
				ctx.lineTo(this.x + this.length, this.y);
				
				if (this.isCyan) {
					ctx.strokeStyle = 'rgba(6, 182, 212, 0.4)';
					ctx.lineWidth = 1.5;
				} else {
					ctx.strokeStyle = 'rgba(255, 255, 255, 0.1)';
					ctx.lineWidth = 1;
				}
				
				ctx.stroke();
			}
		}
		
		function init() {
			initSize();
			particles = [];
			for (let i = 0; i < particleCount; i++) {
				particles.push(new Particle());
			}
		}
		
		function animate() {
			if (!ctx) return;
			// Clear frame
			ctx.clearRect(0, 0, width, height);
			
			// Update and draw
			particles.forEach(p => {
				p.update();
				p.draw();
			});
			
			requestAnimationFrame(animate);
		}
		
		// Event listeners
		window.addEventListener('resize', () => {
			initSize();
		});
		
		canvas.addEventListener('mousemove', (e) => {
			const rect = canvas.getBoundingClientRect();
			mouse.x = e.clientX - rect.left;
			mouse.y = e.clientY - rect.top;
		});
		
		canvas.addEventListener('mouseleave', () => {
			mouse.x = -1000;
			mouse.y = -1000;
		});
		
		init();
		animate();
	}
</script>
