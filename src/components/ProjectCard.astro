---
export interface Props {
	title: string;
	description: string;
	icon: 'wing' | 'engine' | 'wheel';
	link: string;
}

const { title, description, icon, link } = Astro.props;
---

<a href={link} target="_blank" rel="noopener noreferrer" class="group block h-full">
	<article class="h-full bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl p-8 shadow-xl shadow-cyan-500/5 transition-all duration-300 transform group-hover:-translate-y-2 group-hover:border-cyan-500/50 group-hover:bg-white/10 flex flex-col justify-between relative overflow-hidden">
		
		<!-- Speed Lines / Carbon Pattern (visible on hover) -->
		<div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" style="background-image: repeating-linear-gradient(45deg, transparent, transparent 4px, rgba(255,255,255,0.02) 4px, rgba(255,255,255,0.02) 8px);"></div>

		<div class="mb-8 relative z-10">
			<!-- Minimalist SVG Icons based on the prop -->
			<div class="w-12 h-12 flex items-center justify-center rounded-xl bg-white/5 border border-white/10 group-hover:border-red-500/30 transition-all duration-500 text-slate-500 group-hover:text-red-500 transform group-hover:translate-x-2">
				{icon === 'wing' && (
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
						<!-- F1 Front Wing simplified -->
						<path d="M2 12 h20 M4 12 l2 -4 h12 l2 4 M6 8 h12 M10 12 v4 M14 12 v4 M8 16 h8"/>
					</svg>
				)}
				
				{icon === 'engine' && (
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
						<!-- V6 Engine simplified -->
						<path d="M12 2v20 M7 5l5 5 M17 5l-5 5 M7 11l5 5 M17 11l-5 5 M5 5v14 M19 5v14"/>
					</svg>
				)}
				
				{icon === 'wheel' && (
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
						<!-- Technical Steering Wheel -->
						<circle cx="12" cy="12" r="10" />
						<path d="M4 12 h16 M12 4 v16 M8 8 l8 8 M16 8 l-8 8" />
						<circle cx="12" cy="12" r="4" />
					</svg>
				)}
			</div>
		</div>
		
		<div>
			<h3 class="text-sm font-bold tracking-widest text-slate-100 mb-2 group-hover:text-cyan-400 transition-colors uppercase">
				{title}
			</h3>
			<p class="text-sm text-slate-400 leading-relaxed font-light">
				{description}
			</p>
		</div>
		
		<div class="mt-8 flex justify-end">
			<div class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center group-hover:bg-cyan-500/20 group-hover:border-cyan-500/50 transition-colors">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-500 group-hover:text-cyan-400 transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all">
					<line x1="5" y1="19" x2="19" y2="5"></line>
					<polyline points="10 5 19 5 19 14"></polyline>
				</svg>
			</div>
		</div>
	</article>
</a>
