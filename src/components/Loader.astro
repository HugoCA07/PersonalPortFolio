---
<div id="loader" class="fixed inset-0 z-[100] flex items-center justify-center bg-[#080c10] transition-opacity duration-700">
	<!-- F1 Tire Minimalist SVG -->
	<svg class="w-16 h-16 text-cyan-500 animate-spin" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
		<circle cx="50" cy="50" r="45" stroke="currentColor" stroke-width="4" stroke-dasharray="10 10" />
		<circle cx="50" cy="50" r="30" stroke="currentColor" stroke-width="2" />
		<circle cx="50" cy="50" r="15" fill="currentColor" />
		<!-- Spoke lines -->
		<path d="M50 20 L50 35 M50 65 L50 80 M20 50 L35 50 M65 50 L80 50 M29 29 L39 39 M61 61 L71 71 M29 71 L39 61 M61 39 L71 29" stroke="currentColor" stroke-width="2" />
	</svg>
</div>

<script>
	window.addEventListener('load', () => {
		const loader = document.getElementById('loader');
		if (loader) {
			loader.style.opacity = '0';
			setTimeout(() => {
				loader.style.display = 'none';
			}, 700);
		}
	});
</script>
